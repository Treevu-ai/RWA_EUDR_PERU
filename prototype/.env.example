# Copiar a .env y ajustar (no commitear secretos reales).
# Ver prototype/README.md

# Puerto del backend Express (Vite suele usar 5173 en otro proceso)
PORT=3000

# Opcional: producción / desarrollo (si extendéis configuración)
# NODE_ENV=development

# Copiloto EUDR — OPENAI_API_KEY sirve para (1) embeddings de consulta en modo híbrido y (2) modo asistido LLM
# Pegar aquí solo en .env local (no en este archivo): OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
